#include <bits/stdc++.h>
#include <iostream>
using namespace std;

int main()
    {int n;cin>>n;int licznik=0; int i;int j;int l;
    vector<int>a(n);vector<int>k(n);
    for(int i=0;i<n;i++) {cin>>a[i]; } //wczytujemy a[i]
    for(int i=0;i<n;i++)  {cin>>k[i];} //wczytujemy k[i]
    for(int i=0;i<n;i++){if(k[i]==0) a[i]=-a[i];} //zamieniamy dwa wektory w jeden
    for(int i=0;i<n;i++){k.pop_back();}//usuwamy wektor k
    //for(int i=0;i<n;i++) {cout<<a[i]; }
    vector<int>s(0);//deklarujemy stos
    j=n-1;l=0;//deklarujemy zmienne czasowe
    while((a[j]>0)&&(j>=0))  {licznik++;j--; a.pop_back();}//usuwamy sobie rybki z konca, ktore przezyja
    while((j>=0))
    {
        if(a[j]<0) {s.push_back(a[j]);l++;j--;}
        if(a[j]>0)
        {
            while((l>0)&&(a[j]>abs(s[l-1])))
            {   
               s.pop_back();l--; 
            }
            if(s.size()==0){licznik++;}
            j--;
        }
    }
    cout<<licznik+s.size();
    return 0;
    }
