#include <bits/stdc++.h>
#include <iostream>

using namespace std;
int nwd(int a, int b)
{
    if(a%b==0) return b;
    else return nwd(b,a%b);
}
  
int main()
{
    
   int d; int n; int z; 
   cin>>z;
  vector<int> wynik(z+3);
   for (int i=0; i<z; i++){
       cin>>n; cin>>d;
       if(d%n==0) wynik[i]=1;
       else{
            d=d%n;
            wynik[i]=n/nwd(n,d);
       
       }  
   }

   for(int i=0;i<z;i++) cout<<wynik[i]<<endl;
    return 0;
}
