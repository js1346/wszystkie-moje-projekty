int test(int k){
    int hel=k-1;
    if(t[hel]==0) return 0;
    else { 
        hel=hel+k;
        while(hel<n){
            if(t[hel]-t[hel-k]==0) return 0; 
            hel=hel+k;
        }
        return n/k;
    }
}

