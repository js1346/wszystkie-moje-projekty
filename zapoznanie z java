    static int gcd(int a, int b) {
        if (b == 0) return a;
        if (a == 0) return b;
        if (a == b) return a;
        else if (b > a) return gcd(b % a, a);
        else return gcd(a % b, b);
    }


    // liczy największy wspólny dzielnik argumentów
    public static int nwd(int a, int b) {
        return gcd(a, b);
    }

    // liczy i-tą liczbę Fibonacciego
    public static long fib(int i) {
        int[] tab = new int[i + 1];
        tab[0] = 0;
        tab[1] = 1;
        for (int j = 2; j <= i; j++) {
            tab[j] = tab[j - 1] + tab[j - 2];
        }
        return tab[i];
    }

    public static long binom(int n, int k) {
        //n-k+1...n/k
        long toret = 1;
        for (int i = k + 1; i <= n; i++) {
            toret *= i;
            //System.out.println(toret);
        }
        for (int i = 1; i <= n - k; i++) {
            toret /= i;
            // System.out.println(toret);
        }
        return toret;
    }

    static int factor(int n) {
        for (int i = 2; i * i <= n; i++) {
            if (n % i == 0) return i;
        }
        return -1;
    }

    // wypisuje na standardowe wyjście rozkład na czynniki pierwsze argumentu
    public static void factorization(int n) {
        if (n < 0) System.out.print(-1 + " ");
        if (n == 0) System.out.print(0 + " ");
        int help = 0;
        while (n != 1) {
            help = factor(n);
            if (help == -1) {
                System.out.print(n + " ");
                n = 1;
            } else {
                System.out.print(help + " ");
                n /= help;
            }
        }
    }

    static long pow(int n, int t) {
        long toret = 1;
        if (t == 0) return 1;
        else if (t % 2 == 0) {
            t >>= 1;
            long help = pow(n, t);
            toret = toret * help * help;
        } else if (toret % 2 == 1) {
            t -= 1;
            toret *= n;
        }
        return toret;
    }

    // liczy n^t w czasie O(log t) (tzw. "szybkie potęgowanie")
    public static long power(int n, int t) {
        return pow(n, t);
    }


    public static void writeTable(int[] tab){
        for(int i=0;i<tab.length;i++) {
