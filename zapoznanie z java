    }
    public static int[] computeSieve(int n) {
        int[] tab = new int[n + 1];
        tab[0] = 0;
        tab[1] = 1;
        for (int i = 2; i <= n; i++) {
            if (tab[i] == 0) {
                tab[i] = i;
                for (int j = 2 * i; j<= n; j+=i) if(tab[j]==0) tab[j]=i;
            }
        }
        return tab;
    }
    static int max(int a,int b){
        if(a>=b) return a;
        else return b;
    }

    // liczy część wspólną tablic wejściowych A i B
    // zakładamy że tablice A,B są posortowane rosnąco i nie zawierają powtórzeń
    public static int[] intersection(int[] A, int[] B) {
        int help=max(A.length,B.length);
        int[] tab=new int[help];
        int a=0,b=0,counter=0;
        while(a<A.length||b<B.length){
            if(A[a]<B[b])a++;
            else if(A[a]>B[b])b++;
            else if(A[a]==B[b]){
                tab[counter]=A[a];
                a++;
                b++;
                counter++;
            }
        }
        return tab;
    }
}
