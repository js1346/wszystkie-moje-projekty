#include <bits/stdc++.h>
#include <iostream>
using namespace std;

long long w[1000005]; 
long long sumpref[1000005];

int main()
{
    long long n; cin>>n;
    long long suma=0;
    long long r=0,wynik=0;
    
    for(int i=1;i<=n;i++){
        cin>>w[i];
        suma += w[i];
    }
    sumpref[0]=0;
    w[0]=0;
    
    suma /=n;//suma przestaje byc suma a staje sie pomocnicza!!!!
    for(int i=1;i<=n;i++) w[i]-= suma;
    
    for(int i=1;i<=n;i++) sumpref[i]=sumpref[i-1]+w[i];
    
    /*for(int i=0;i<=n;i++) cout<<w[i]<<" ";
    cout<<endl;
    for(int i=0;i<=n;i++) cout<<sumpref[i]<<" ";*/
    
    for(int i=1;i<=n;i++)
    {
        wynik += w[i];
        if(wynik!=0) r++;
    }
    cout<<r;
    return 0;
}
