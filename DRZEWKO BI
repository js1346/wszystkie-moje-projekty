#include <iostream>
#include <math.h>
using namespace std;

int a[5000000];

//14//  4  3  8 4  6 3 0 12  11 6 4 10 12 7 11 10

int main()
{
    int ka; 
    cin>>ka;
    //cout<<pow(2,ka);
    for(int i=1;i<pow(2,ka);i++) cin>>a[i];
    
    for(int j=pow(2,ka-2);j>0;j=j/2){
        for(int i=2*j;i<4*j;i=i+2){
            if(a[i]<a[i+1]) a[i/2] +=a[i];
            else a[i/2] +=a[i+1];
        }
        
    }
    cout<<a[1];

    return 0;
}
