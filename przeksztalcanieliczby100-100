long long rozklad (long long x)
{ long long sumaczynnikow=0;long long k=2;
 while(x>1&&k<=sqrt(x))
    {
        while(x%k==0)
        {
            sumaczynnikow=sumaczynnikow+k;
            x=x/k;
        }
        k++;
    }
    if (x==1) return sumaczynnikow;
    else return sumaczynnikow+x;
}
long long nwd(long long a, long long b)
    {long long pomoc;
        while(b>0)
            {
                pomoc=a;
                a=b;
                b=pomoc%b;
            }
        return a;
    
