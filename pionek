#include <iostream>
#include <bits/stdc++.h>
using namespace std;

int p[1000010];
int s[1000010];

int main()
{
    int j;
    int n;cin>>n;
    for(int i=0;i<n;i++) cin>>p[i];
     
    s[0]=p[0];
    for(int i=1;i<n;i++)
    {
       
       s[i]=p[i]+s[i-1]; 
       j=i-2;
        while( (j>=0) && (j>i-7) ){
            s[i]=max(s[i],p[i]+s[j]);
            j--;
        }
    }
    cout<<s[n-1];

    return 0;
}
