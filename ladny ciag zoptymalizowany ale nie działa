#include <algorithm>
#include <vector>
#include <iostream>
#define pii pair <int,int>

using namespace std;

//  3 1 10  1 2 3
//11//3 4 15 7 1 5 
bool compar(pii a , pii b){
    return a.second < b.second;
}

bool porow(pii a, pii b){
    return a.first<b.first;
}

int main()
{
    int n,k,q;
    cin>>n>>k>>q;
    pii d[1005];
    vector <int> c1(k+3);
    vector <int> c2(k+3);
    
    for(int i=0;i<n;i++) {cin>>d[i].first; d[i].second=i;}
    sort( d , d+n-1,porow);
    
    //for(int i=0;i<n;i++) cout<<d[i]<<" ";
    //cout<<endl;
    
    for(int i=1;i<=k+1;i++) {c1[i]=1;c2[i]=1;}
    
    int id=0;int licznik=1;int wynik;
    while(id<n){
        
          //for(int i=1;i<=k+1;i++) cout<<c1[i]<<" ";
      //  cout<<endl;
        
        while(d[id].first==licznik){
            wynik=0;
            for(int i=1;i<=k+1;i++) wynik=(wynik+c1[i])%q;
            d[id].first=wynik;
            id++;
        }
        
        c1[0]=0;c1[k+2]=0;
        
        for(int i=1;i<=k+1;i++){
           // cout<<c1[i-1]<<" "<<c1[i+1];
            c2[i] =(c1[i]+c1[i-1]+c1[i+1])%q;
        }
        
        for(int i=1;i<=k+1;i++) c1[i]=c2[i];
      
        
        licznik++;
    }
    sort(d, d+n-1,compar);
    for(int i=0;i<n;i++) cout<<d[i].first<<" ";
    return 0;
}
